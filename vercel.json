{
    "version": 2,
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": ["public/**/*", "dist/**/*"]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ],
    "env": {
        "JWT_SECRET": "your_jwt_secret_value",
        "MONGO_CONNECT_URL": "your_mongo_connect_url"
    }
}
