{
    "version": 2,
    "builds": [
        {
            "src": "index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.ts"
        }
    ],
    "env": {
        "MONGO_CONNECT_URL": "@mongo_connect_url",
        "JWT_SECRET": "@jwt_secret"
    }
}
